# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit — see .env.example)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase
.firebase/
.firebase-data/
firebase-debug.log
firestore-debug.log
ui-debug.log
*.firebase-cache
serviceAccount*.json
firebase-adminsdk-*.json

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# OS
Thumbs.db

# Local AI / agent state
.agents/
.genkit/

# Claude Code per-machine local state (settings.json IS committed, the rest is not)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/cache/
.claude/logs/
