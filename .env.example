# =============================================================================
# Xanthix.ai — Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit .env*.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Everything else stays server-side only.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase — Client SDK (PUBLIC — used by browser code)
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=xanthixai.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=xanthixai
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=xanthixai.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firestore database ID. The first DB you create is "(default)"; named
# databases (Firestore Multi-DB) use the bare name. Leave as "(default)"
# unless your project's primary DB has a custom name.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=(default)

# Firebase App Check (reCAPTCHA Enterprise site key — public)
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# Use Firebase emulators during local dev (true/false)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# -----------------------------------------------------------------------------
# Firebase — Admin SDK (SERVER ONLY — never expose)
# Either provide a service account JSON path OR the inline credentials.
# In production on Cloud Run / Functions / App Hosting, application default
# credentials are used automatically — leave these empty there.
# -----------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=
# Or alternatively (one-line JSON):
# FIREBASE_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# AI Providers (SERVER ONLY)
# -----------------------------------------------------------------------------
# Vertex AI (Gemini via Firebase project billing — preferred path)
# Region: defaults to us-central1. For EU residency, switch to europe-west4
# once the required Gemini models are GA there.
VERTEX_AI_LOCATION=us-central1

# Google AI Studio (legacy / dev fallback only — NOT used by router anymore)
GEMINI_API_KEY=

# Anthropic Claude (used for premium tier projects)
ANTHROPIC_API_KEY=

# OpenAI (fallback / specific tasks)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Stripe (SERVER ONLY for secret, PUBLIC for publishable)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Xanthix.ai
NODE_ENV=development
